{
  "name": "catnip-intro-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsc && node dist/app.js",
    "build": "tsc",
    "start": "node dist/app.js",
    "prisma:generate": "DATABASE_URL=\"file:../../data/company.db\" prisma generate --schema prisma/schema.prisma",
    "prisma:push": "DATABASE_URL=\"file:../../data/company.db\" prisma db push --schema prisma/schema.prisma --skip-generate",
    "prisma:migrate": "DATABASE_URL=\"file:../../data/company.db\" prisma migrate dev --name init --schema prisma/schema.prisma",
    "db:seed": "DATABASE_URL=\"file:../../data/company.db\" node dist/scripts/seed.js",
    "db:check": "DATABASE_URL=\"file:../../data/company.db\" node dist/scripts/check-db.js"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "cors": "^2.8.5",
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "prisma": "6.19.0",
    "typescript": "^5.3.3"
  }
}
